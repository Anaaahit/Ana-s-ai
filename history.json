                    "path": "isPrime.js",
                    "content": "/**\n * Checks if a number is prime.\n * @param {number} n\n * @returns {boolean}\n */\nfunction isPrime(n) {\n  if (n <= 1) return false;\n  if (n <= 3) return true;\n  if (n % 2 === 0 || n % 3 === 0) return false;\n  for (let i = 5; i * i <= n; i += 6) {\n    if (n % i === 0 || n % (i + 2) === 0) return false;\n  }\n  return true;\n}\n\n// Simple test cases\nconst testCases = [1, 2, 3, 4, 11, 15, 17, 20, 29];\ntestCases.forEach(num => {\n  console.log(`${num} is prime: ${isPrime(num)}`);\n});\n"
